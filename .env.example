# -----------------------------------------------------------------------------
# ALLO INVENTORY — ENVIRONMENT VARIABLES CONFIGURATION (.env)
# -----------------------------------------------------------------------------

# 1. Database Connection (Neon DB - Serverless PostgreSQL)
# DATABASE_URL: Neon Connection string with pooling enabled (uses transaction mode on port 5432 or 6543)
# DIRECT_URL: Neon connection string with pooling disabled (direct mode, required for Prisma migrations)
DATABASE_URL="postgresql://[user]:[password]@[project-id]-pooler.[region].aws.neon.tech/[db-name]?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://[user]:[password]@[project-id].[region].aws.neon.tech/[db-name]?sslmode=require"

# 2. Redis Connection (Upstash Redis - Serverless Native REST API)
# Get these credentials from your Upstash console (console.upstash.com)
UPSTASH_REDIS_REST_URL="https://[project-id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[your-rest-token]"

# 3. Security Credentials & Background Task Triggers
# CRON_SECRET: A strong randomized alphanumeric string. Used to protect the /api/cron endpoint from external abuse.
CRON_SECRET="your_highly_secure_randomized_token"
